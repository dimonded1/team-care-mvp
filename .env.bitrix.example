# Copy these values into server-only environment configuration. Do not expose them to Vite (no VITE_ prefix).
BITRIX_ENABLED=false
# Full Bitrix incoming-webhook base URL. Keep the token server-side.
BITRIX_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/<user_id>/<webhook_token>
# Secret for authorizing requests to your own future server endpoint; it is not sent to Bitrix.
BITRIX_WEBHOOK_SECRET=<server-only-secret>
BITRIX_CARE_EVENT_ENTITY_TYPE_ID=<smart-process-entity-type-id>
BITRIX_GUARDIANSHIP_FORM_ID=<guardianship-form-id>
BITRIX_FIELD_GUARDIAN_NAME=<guardian-name-field-id>
BITRIX_FIELD_GUARDIAN_EMAIL=<guardian-email-field-id>
BITRIX_FIELD_GUARDIAN_PHONE=<guardian-phone-field-id>
BITRIX_FIELD_ANIMAL_ID=<animal-id-field-id>
BITRIX_FIELD_ANIMAL_NAME=<animal-name-field-id>
BITRIX_FIELD_CONSENT=<consent-field-id>
BITRIX_FIELD_CARE_TYPE=<care-type-field-id>
BITRIX_FIELD_OCCURRED_AT=<occurred-at-field-id>
